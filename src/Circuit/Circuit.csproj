<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>CircuitDotNet</PackageId>
    <Description>Primary C# Circuit package for typed composition in agentic .NET applications.</Description>
    <PackageTags>circuit;agents;dotnet;csharp</PackageTags>
    <NoWarn>$(NoWarn);RS0016;RS0017;RS0037</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Circuit.Core/Circuit.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
